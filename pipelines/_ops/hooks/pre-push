#!/bin/bash
# Este arquivo é versionado em: pipe/data_plataform/pipelines/_ops/hooks/pre-push
# Ele é copiado para .git/hooks/pre-push pelo script setup.py

echo "🛡️  [Git Hook] Validando integridade antes do Push..."

# Define o caminho do script de verificação relativo à raiz do projeto
CHECK_SCRIPT="data_plataform/pipelines/_ops/check_imports.py"

# Verifica se o script existe
if [ ! -f "$CHECK_SCRIPT" ]; then
    echo "⚠️  Aviso: Script de verificação não encontrado em $CHECK_SCRIPT"
    echo "   O push seguirá sem validação."
    exit 0
fi

# Executa o verificador Python
# O python deve estar no PATH do desenvolvedor
python "$CHECK_SCRIPT"
EXIT_CODE=$?

if [ $EXIT_CODE -ne 0 ]; then
    echo ""
    echo "❌ BLOQUEADO: Seu código possui erros de importação ou sintaxe."
    echo "   Corrija os erros acima antes de enviar para o servidor."
    exit 1
fi

echo "✅ Código validado! Enviando..."
exit 0